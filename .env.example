VITE_API_BASE_URL=http://localhost:8787/api
PORT=8787
GOVERNANCE_DATA_MODE=mock
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_AUTHENTICATOR=externalbrowser
SNOWFLAKE_ROLE=PUBLIC
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=PPRM_PROD
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_HOST=

# GenAI (optional – for consultation & summary analysis)
# Endpoint: https://YOUR_RESOURCE.openai.azure.com (no trailing path)
AZURE_OPENAI_ENDPOINT=https://jules-aiml-2.openai.azure.com
AZURE_OPENAI_API_KEY=
# Must match the deployment name exactly in Azure Portal (e.g. gpt-4o, gpt-4, o4-mini)
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
# Optional; code tries 2024-02-15-preview, 2023-05-15, etc. if not set
AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Optional: reduce intermittent "fetch failed" – request timeout (ms) and retries (default 90000, 3)
# AZURE_OPENAI_TIMEOUT_MS=90000
# AZURE_OPENAI_MAX_RETRIES=3

# Optional: use Python LLM backend for summary (if Node Azure returns 404). When set, summary is requested from this URL first.
# Run: python -m uvicorn backend_llm.app:app --reload --host 0.0.0.0 --port 8000
# LLM_BACKEND_URL=http://localhost:8000
